APP_NAME="AI Video Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aivideo
DB_USERNAME=root
DB_PASSWORD=

# ── Queue (Redis required for async render/avatar/publish jobs) ───────────
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (optional) ────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025

# ── Video engine ───────────────────────────────────────────────────────────
# Absolute path to the remotion-pro directory
VIDEO_ENGINE_PATH=/path/to/aivideo/video-engine/remotion-pro

# Path to FFmpeg binary (or just 'ffmpeg' if on PATH)
FFMPEG_PATH=ffmpeg

# Path to Laravel public storage (used by render-worker.js to find avatar MP4s)
LARAVEL_STORAGE_PUBLIC=/path/to/aivideo/backend/storage/app/public

# ── Piper TTS (optional — enables in-browser "Generate Narration") ─────────
# Download: bash video-engine/scripts/download-voice.sh
PIPER_VOICE_PATH=/path/to/aivideo/video-engine/voices/ryan.onnx
PIPER_CMD=python3 -m piper

# ── Image generation (all optional — Pollinations.ai works without any key) ─
GEMINI_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=
HF_TOKEN=

# ── Music generation ────────────────────────────────────────────────────────
# Mubert free tier: https://mubert.com/render/pricing
MUBERT_API_KEY=

# ── SadTalker (talking avatar via HF Spaces, free) ──────────────────────────
# Default works out of the box — override to use a private/faster space
SADTALKER_SPACE=vinthony/SadTalker

# ── YouTube publishing ──────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com → enable YouTube Data API v3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/social/callback/youtube

# ── Instagram / Meta publishing ─────────────────────────────────────────────
# Create a Meta app at https://developers.facebook.com → add Instagram Graph API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/social/callback/instagram

# ── Wave SaaS settings ──────────────────────────────────────────────────────
WAVE_DEMO=false

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=1440
